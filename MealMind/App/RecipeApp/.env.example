# Copy to `.env` and fill in from Supabase: Project Settings → API
EXPO_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
# Optional: MealMind Express API (uses Supabase JWT in Authorization header)
EXPO_PUBLIC_API_URL=http://localhost:3000

# Google AI (Gemini) — ingredient scan from photos. Key is exposed in the client bundle; use a backend proxy for production.
# Free tier has strict rate/usage limits (HTTP 429). If you hit limits, wait, scan less often, or enable billing in AI Studio.
# https://aistudio.google.com/apikey
EXPO_PUBLIC_GEMINI_API_KEY=
# Optional override (default: gemini-2.0-flash)
# EXPO_PUBLIC_GEMINI_MODEL=gemini-2.0-flash
