# Copy to `.env` and fill in from Supabase: Project Settings → API
EXPO_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
#
# OAuth (Google + Apple): enable each provider under Supabase → Authentication → Providers (client IDs / secrets live in Supabase, not in this file).
# Redirect URLs: Supabase → Authentication → URL configuration.
# If the redirect URL is not allowlisted, Supabase sends the browser to Site URL — often http://localhost:3000, which fails on a phone.
# Add these under Additional Redirect URLs (wildcards are supported):  exp://**   and   recipeapp://**
# Set Site URL to a real https:// origin (not http://localhost) for mobile testing.
# The app uses recipeapp://auth/callback in dev builds and exp://YOUR_LAN:8081/--/auth/callback in Expo Go (see Metro log line [OAuth] redirect_to).
# Optional exact override:
# EXPO_PUBLIC_AUTH_REDIRECT_URI=
#
# Optional: MealMind Express API (uses Supabase JWT in Authorization header)
EXPO_PUBLIC_API_URL=http://localhost:3000

# Ingredient photo scan — keys are exposed in the client bundle; prefer a backend proxy in production.
# Provider order: unset = try OpenAI first, then Gemini. Use: openai | gemini | gemini_first
# EXPO_PUBLIC_INGREDIENT_SCAN_PROVIDER=

# OpenAI (vision) — https://platform.openai.com/api-keys
EXPO_PUBLIC_OPENAI_API_KEY=
# Vision model (default: gpt-4o-mini)
# EXPO_PUBLIC_OPENAI_VISION_MODEL=gpt-4o-mini
# Text recipe generation on Home → Find My Meal (default: gpt-4o-mini)
# EXPO_PUBLIC_RECIPE_AI_MODEL=gpt-4o-mini
#
# Recipe card images: with EXPO_PUBLIC_OPENAI_API_KEY set, heroes default to DALL·E 3 (profile + home filters + ingredients + each dish).
# Override order: generated_first | unsplash_first | generated_only | unsplash_only (stock_only)
# EXPO_PUBLIC_RECIPE_HERO_IMAGE_MODE=unsplash_first
# DALL·E 3 options (optional): EXPO_PUBLIC_DALLE_IMAGE_SIZE=1024x1024 | 1792x1024 | 1024x1792
# EXPO_PUBLIC_DALLE_IMAGE_QUALITY=standard | hd
#
# Optional: Unsplash Access Key — stock heroes when mode allows (imageQuery + title + ingredients)
# https://unsplash.com/oauth/applications
# EXPO_PUBLIC_UNSPLASH_ACCESS_KEY=

# Google AI (Gemini) — https://aistudio.google.com/apikey — free tier can return HTTP 429 often.
EXPO_PUBLIC_GEMINI_API_KEY=
# EXPO_PUBLIC_GEMINI_MODEL=gemini-2.0-flash

# Optional: YouTube Data API v3 key — recipe “Watch tutorial” opens the #1 search result (enable API on the key).
# https://console.cloud.google.com/apis/library/youtube.googleapis.com — expose only in client if acceptable for your threat model.
# EXPO_PUBLIC_YOUTUBE_API_KEY=
